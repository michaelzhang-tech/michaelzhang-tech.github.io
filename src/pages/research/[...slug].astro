---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const researchs = await getCollection('research');
  return researchs.map((research) => ({
    params: { slug: research.id },
    props: { research },
  }));
}

const { research } = Astro.props;
const { Content } = await render(research);

const formattedDate = research.data.pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${research.data.title} - Research`} description={research.data.description}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="mb-10">
      <div class="flex items-center gap-2 text-sm text-blue-600 dark:text-blue-400 font-medium mb-4">
        <span>{research.data.category}</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-slate-100 mb-4">{research.data.title}</h1>
      <time class="text-slate-500 dark:text-slate-400">{formattedDate}</time>
    </header>
    
    {research.data.pdfUrl && (
      <div class="mb-10 p-4 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
        <a href={research.data.pdfUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-medium">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          下载 PDF 报告
        </a>
      </div>
    )}
    
    <div class="prose prose-slate prose-lg max-w-none">
      <Content />
    </div>
    
    <footer class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-700">
      <a href="/research" class="text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-medium">← 返回研究报告列表</a>
    </footer>
  </article>
</BaseLayout>