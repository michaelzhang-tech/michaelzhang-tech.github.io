---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About - Michael Zhang" description="关于 Michael Zhang">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <header class="mb-12 text-center">
      <div class="w-32 h-32 mx-auto mb-6 rounded-full bg-slate-200 overflow-hidden">
        <img src="/avatar.jpg" alt="Michael Zhang" class="w-full h-full object-cover" />
      </div>
      <h1 class="text-4xl font-bold text-slate-900 mb-4">关于我</h1>
      <p class="text-lg text-slate-600">技术探索者 · 终身学习者</p>
    </header>
    
    <div class="prose prose-slate prose-lg max-w-none">
      <h2>我是谁</h2>
      <p>你好！我是 Michael Zhang，一名热爱技术的开发者和创作者。我专注于前端开发、系统架构和技术写作。</p>
      
      <h2>我在做什么</h2>
      <ul>
        <li><strong>博客 (Post)</strong>：分享技术文章、教程和最佳实践</li>
        <li><strong>播客 (Podcast)</strong>：录制技术讨论和行业分析节目</li>
        <li><strong>研究 (Research)</strong>：深入调研新技术和工具</li>
      </ul>
      
      <h2>技术栈</h2>
      <div class="flex flex-wrap gap-2 not-prose">
        {['TypeScript', 'React', 'Astro', 'Node.js', 'Python', 'Go'].map((tech) => (
          <span class="px-3 py-1 bg-slate-100 text-slate-700 rounded-full text-sm font-medium">{tech}</span>
        ))}
      </div>
      
      <h2>联系我</h2>
      <ul>
        <li>GitHub: <a href="https://github.com/michaelzhang-tech">@michaelzhang-tech</a></li>
        <li>Email: your-email@example.com</li>
        <li>Twitter: @yourhandle</li>
      </ul>
    </div>
  </div>
</BaseLayout>