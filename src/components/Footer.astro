---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-900 text-slate-300 py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-center">
      <div class="mb-4 md:mb-0">
        <p class="text-sm">© {currentYear} Michael Zhang. All rights reserved.</p>
      </div>
      <div class="flex space-x-6">
        <a href="https://github.com/michaelzhang-tech" target="_blank" rel="noopener" class="hover:text-white transition-colors">
          GitHub
        </a>
        <a href="https://twitter.com" target="_blank" rel="noopener" class="hover:text-white transition-colors">
          Twitter
        </a>
        <a href="mailto:your-email@example.com" class="hover:text-white transition-colors">
          Email
        </a>
      </div>
    </div>
  </div>
</footer>